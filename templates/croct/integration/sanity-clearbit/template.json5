{
  "$schema": "https://schema.croct.com/json/v1/catalog-template.json",
  "title": "Sanity CMS + Clearbit",
  "description": "A template for adding firmographic personalization on a Sanity project.",
  "metadata": {
    "id": "integration/cms/sanity-clearbit",
    "verified": true,
    "ecosystem": {
      "name": "Croct",
      "avatarUrl": "https://github.com/croct-tech.png",
      "websiteUrl": "https://croct.com"
    },
    "documentationUrl": "https://github.com/croct-tech/templates/blob/master/templates/croct/integration/sanity-clearbit/README.md",
    "sourceUrl": "https://github.com/croct-tech/templates/blob/master/templates/croct/integration/sanity-clearbit/template.json5",
    "coverImageUrl": "https://github.com/croct-tech/templates/blob/master/templates/croct/integration/sanity-clearbit/cover.png",
    "installationUrl": "croct://integration/sanity-clearbit",
    "categories": [
      "integration/cms",
      "integration/data-enrichment"
    ],
    "relatedTemplates": [
      "integration/cms/sanity",
      "integration/cms/sanity-ab-testing",
      "integration/cms/sanity-personalization",
      "integration/data-enrichment/clearbit"
    ]
  },
  "actions": [
    {
      "name": "import",
      "template": "croct://integration/sanity",
      "options": {
        "extension": "croct://integration/sanity-clearbit/extension.json5"
      }
    }
  ]
}
