{
  "$schema": "https://schema.croct.com/json/v1/template.json",
  "title": "Strapi AB testing customization",
  "description": "A customization template for the Strapi AB testing template.",
  "options": {
    "slotId": {
      "type": "reference",
      "description": "The variable name that holds the slot ID.",
      "required": true
    },
    "slotVersion": {
      "type": "reference",
      "description": "The variable name that holds the slot version.",
      "required": true
    },
    "pagePath": {
      "type": "string",
      "description": "The path to the page where the slot is used."
    }
  },
  "actions": [
    {
      "name": "create-resource",
      "resources": {


        "audiences": {
          "all-users": {
            "name": "All users",
            "criteria": "true"
          }
        },



        "components": {
          "strapi-dynamic-zone-map": {
            "name": "Strapi - Dynamic zone map",
            "description": "A map for components in a Strapi to slots in Croct.",
            "schema": "${import('croct://integration/strapi/configuration/dynamic-zone-map-schema.json')}"
          },
          "launchpad-hero-section": {
            "name": "LaunchPad - Hero section",
            "description": "Main section with title, tagline, and CTAs.",
            "schema": "${import('croct://integration/strapi/configuration/hero-section-schema.json')}"
          }
        },
        "slots": {
          "launchpad-home-hero": {
            "name": "LaunchPad - Home hero",
            "component": "launchpad-hero-section",
            "content": {
              "en": "${import('croct://integration/strapi/configuration/home-hero-content.en.json')}"
            }
          }
        },




        "experiences": [
          {
            "name": "🧪 Experiment for all users",
            "draft": true,
            "audiences": [
              "all-users"
            ],
            "slots": [
              "launchpad-home-hero"
            ],
            "content": {
              "default": {}
            },
            "experiment": {
              "name": "Tagline copy",
              "goalId": "command-copy",
              "crossDevice": false,
              "traffic": 1,
              "variants": [
                {
                  "name": "Kickstart your project",
                  "content": {
                    "default": {
                      "launchpad-home-hero": {
                        "en": "${import('croct://integration/strapi/configuration/home-hero-content.en.json')}"
                      }
                    }
                  },
                  "baseline": true,
                  "allocation": 500
                },
                {
                  "name": "Integrate in one command",
                  "content": {
                    "default": {
                      "launchpad-home-hero": {
                        "en": "${import('./configuration/home-hero-experience-content.en.json')}"
                      }
                    }
                  },
                  "baseline": false,
                  "allocation": 500
                }
              ]
            }
          }
        ],




      },
      "result": {
        "components": {
          "strapi-dynamic-zone-map": {
            "id": "dynamicZoneMapComponentId"
          }
        },
        "slots": {
          "launchpad-home-hero": {
            "id": "heroSlotId",
            "version": "heroSlotVersion"
          }
        },
        "experiences": {
          "0": "experienceId"
        }
      }
    },
    {
      "name": "replace-file-content",
      "files": [
        {
          "path": "${options.pagePath}",
          "replacements": [
            {
              "pattern": "%workspaceUrl%/slots/edit/%slotId%/%slotVersion%",
              "value": "%workspaceUrl%/experiences/%experienceId%/edit"
            },
            {
              "pattern": "%experienceId%",
              "value": "${this.experienceId}"
            },
            {
              "pattern": "Edit content",
              "value": "Manage experiment"
            },
            {
              "pattern": "utm_content=strapi",
              "value": "utm_content=strapi-ab-testing"
            }
          ]
        }
      ]
    }
  ]
}
