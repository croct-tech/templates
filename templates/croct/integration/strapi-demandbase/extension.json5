{
  "$schema": "https://schema.croct.com/json/v1/template.json",
  "title": "Strapi Demandbase personalization customization",
  "description": "A customization template for the Strapi + Demandbase personalization template.",
  "options": {
    "slotId": {
      "type": "reference",
      "description": "The variable name that holds the slot ID.",
      "required": true
    },
    "slotVersion": {
      "type": "reference",
      "description": "The variable name that holds the slot version.",
      "required": true
    },
    "pagePath": {
      "type": "string",
      "description": "The path to the page where the slot is used."
    }
  },
  "actions": [
    {
      "name": "create-resource",
      "resources": {
        "audiences": {
          "mid-market-financial-services": {
            "name": "Mid-market financial services",
            "criteria": "user's industry is 'Financial Services' and user's employees is 'Mid-market'"
          }
        },
        "experiences": [
          {
            "name": "Mid-market financial services",
            "draft": true,
            "audiences": [
              "mid-market-financial-services"
            ],
            "slots": [
              "${this[options.slotId]}"
            ],
            "content": {
              "default": {
                "${this[options.slotId]}": {
                  "en": "${import('./configuration/home-hero-experience-content.en.json')}"
                }
              }
            }
          }
        ]
      },
      "result": {
        "experiences": {
          "0": "experienceId"
        }
      }
    },
    {
      "name": "replace-file-content",
      "files": [
        {
          "path": "${options.pagePath}",
          "replacements": [
            {
              "pattern": "%workspaceUrl%/slots/edit/%heroSlotId%/%heroSlotVersion%",
              "value": "%workspaceUrl%/experiences/%experienceId%/edit"
            },
            {
              "pattern": "%experienceId%",
              "value": "${this.experienceId}"
            },
            {
              "pattern": "Edit this content",
              "value": "Manage personalized content"
            },
            {
              "pattern": "utm_content=strapi",
              "value": "utm_content=strapi-demandbase"
            }
          ]
        }
      ]
    }
  ]
}
